manifest {
    name            = 'angelovangel/faster-report'
    author          = 'Angel Angelov'
    homePage        = 'https://github.com/angelovangel/faster-report'
    description     = 'Generate interactive HTML quality control reports for FASTQ/BAM files.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=21.04.0'
    version         = '1.0.0'
}

params {
    reads     = null
    type      = null
    rundate   = null
    flowcell  = null
    basecall  = null
    user      = null
    save_raw  = false
    subsample = 1.0
    outfile   = 'faster-report.html'
    outdir    = 'output'
    help      = false
}

docker {
    enabled = true
    // remove the flag below if you don't need $HOME mounted (e.g. paths outside home)
    // runOptions = "--mount type=bind,src=\$HOME,target=\$HOME"
}

process {
    cpus      = 4
    memory    = '8 GB'
}

// Uncomment and adjust if your fastq files live outside the default
// Nextflow work/staging area (e.g. large ONT run folders on a shared mount)
// docker.runOptions = "--mount type=bind,src=${System.getenv('HOME')},target=${System.getenv('HOME')}"
