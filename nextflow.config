docker {
    enabled = true
    // remove the flag below if you don't need $HOME mounted (e.g. paths outside home)
    // runOptions = "--mount type=bind,src=\$HOME,target=\$HOME"
}

process {
    container        = 'aangeloo/faster-report'
    // the image sets ENTRYPOINT ["/temp/faster-report.R"], which Docker prepends
    // to whatever command Nextflow passes in, breaking argument parsing.
    // Clearing the entrypoint lets Nextflow's own /bin/bash -c "..." wrapper run normally.
    containerOptions = "--entrypoint ''"
    cpus      = 4
    memory    = '8 GB'
}

// Uncomment and adjust if your fastq files live outside the default
// Nextflow work/staging area (e.g. large ONT run folders on a shared mount)
// docker.runOptions = "--mount type=bind,src=${System.getenv('HOME')},target=${System.getenv('HOME')}"
